# LLM API Configuration (omlx)
# omlx serves large text + vision models via an OpenAI-compatible API
LLM_BASE_URL=https://your-omlx-server/v1
LLM_API_KEY=replace-me
LLM_TEXT_MODEL=gpt-oss-120b-MXFP4-Q8
LLM_SMALL_VISION_MODEL=Qwen3.6-35B-A3B-4bit
LLM_LARGE_VISION_MODEL=Qwen3.6-35B-A3B-4bit

# Embedding / Reranker (LM Studio — running locally on default port 1234)
# macOS/Windows Docker: use host.docker.internal instead of 127.0.0.1
EMBEDDING_BASE_URL=http://host.docker.internal:1234/v1
EMBEDDING_API_KEY=not-needed
EMBEDDING_MODEL=text-embedding-bge-reranker-v2-m3

# Database — leave as-is when using docker-compose (the compose file overrides to use the postgres container)
DATABASE_URL=postgresql://hillmantam@localhost:5432/pprfs_vetting

# Frontend Port
PORT=7676

# Backend Port
BACKEND_PORT=8043

# Stamp/chop recovery passes (0=off, 1 or 2 extra LLM passes per page focused on stamps)
STAMP_RECOVERY_PASSES=1
